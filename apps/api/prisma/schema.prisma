// 프롤로그 Prisma 스키마 v0.1
//
// 작성 기준: 08_데이터항목_정의서_v_0_1.md
// 기획 문서의 엔티티/필드/enum 을 가능한 그대로 옮겼다.
// 컬럼명은 정의서의 snake_case → camelCase 로만 변환.
//
// 변경 시:
// 1. 데이터항목 정의서와 어긋나면 정의서를 먼저 갱신할지 확인
// 2. `pnpm --filter api prisma migrate dev --name <설명>` 실행
// 3. 영향받는 DTO/서비스/UI 모두 수정
// 4. CLAUDE.md 의 "데이터 변경 작업 패턴" 절 준수

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 일반 쿼리는 connection pooler 사용 (Supabase 의 pgbouncer, port 6543)
  url       = env("DATABASE_URL")
  // 마이그레이션은 direct connection 사용 (port 5432)
  directUrl = env("DIRECT_URL")
}

// =====================================================================
// 1. User & Consent
// =====================================================================

enum UserStatus {
  pending      // 가입했지만 필수 인증/프로필 미완료
  active       // 서비스 이용 가능
  suspended    // 제재 또는 운영 제한
  withdrawn    // 탈퇴
}

enum MembershipType {
  free
  plus
  trust_plus   // MVP 후순위
}

enum Gender {
  male
  female
  other        // 미공개 또는 별도 정책 결정 시 사용
}

enum LoginProvider {
  phone
  kakao
  apple
}

model User {
  id              String         @id @default(cuid())
  // 휴대폰 번호는 평문 저장 금지. SHA-256(서버 pepper) 만 저장.
  phoneHash       String         @unique
  email           String?        @unique
  loginProvider   LoginProvider
  gender          Gender
  birthYear       Int
  targetGender    Gender
  region1         String         // 시/도
  region2         String?        // 시/군/구
  status          UserStatus     @default(pending)
  membershipType  MembershipType @default(free)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  withdrawnAt     DateTime?

  // 관계
  consents              UserConsent[]
  auth                  UserAuth?
  profile               Profile?
  profileAnswers        ProfileAnswer[]
  relationshipPreference RelationshipPreference?
  photos                Photo[]
  recommendationsReceived Recommendation[] @relation("RecommendationReceiver")
  recommendationsAsTarget Recommendation[] @relation("RecommendationTarget")
  actionsByUser         UserAction[]      @relation("ActionByUser")
  actionsTowardUser     UserAction[]      @relation("ActionTowardUser")
  matchesAsUserA        Match[]           @relation("MatchUserA")
  matchesAsUserB        Match[]           @relation("MatchUserB")
  conversationsAsUserA  Conversation[]    @relation("ConvUserA")
  conversationsAsUserB  Conversation[]    @relation("ConvUserB")
  messagesSent          Message[]
  contactExchangesAsRequester ContactExchange[] @relation("ContactRequester")
  contactExchangesAsResponder ContactExchange[] @relation("ContactResponder")
  reportsFiled          Report[] @relation("ReportFiler")
  reportsReceived       Report[] @relation("ReportTarget")
  blocksMade            Block[]  @relation("BlockerUser")
  blocksReceived        Block[]  @relation("BlockedUser")
  payments              Payment[]
  refreshTokens         RefreshToken[]

  @@index([status, gender, targetGender])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  // 회전 추적용
  replacedById String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

model UserConsent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType String   // terms_of_service, privacy, marketing, location, ...
  required    Boolean
  agreed      Boolean
  version     String
  agreedAt    DateTime @default(now())

  @@index([userId, consentType])
  @@map("user_consents")
}

// =====================================================================
// 2. UserAuth (인증 상태)
// =====================================================================

enum FaceMatchStatus {
  not_submitted
  pending
  verified
  rejected
}

enum EmploymentVerificationStatus {
  not_submitted
  pending
  verified
  rejected
}

model UserAuth {
  id                          String                       @id @default(cuid())
  userId                      String                       @unique
  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 본인 인증 (FR-B01)
  identityVerified            Boolean                      @default(false)
  identityVerifiedAt          DateTime?
  // 본인 인증 응답에서 CI 만 해시 저장. 이름/생년월일은 저장하지 않는다.
  identityCiHash              String?
  identityProvider            String?                      // pass, nice 등

  // 얼굴 인증 (FR-B02)
  faceMatchStatus             FaceMatchStatus              @default(not_submitted)
  faceVerifiedAt              DateTime?
  faceConfidence              Float?

  // 나이 확인 (FR-B03)
  ageVerified                 Boolean                      @default(false)

  // 매너 서약 (FR-B05)
  mannerPledgeAgreed          Boolean                      @default(false)
  mannerPledgeAgreedAt        DateTime?

  // 싱글 상태 서약 (FR-B06)
  singlePledgeAgreed          Boolean                      @default(false)
  singlePledgeAgreedAt        DateTime?

  // 직업/재직 인증 (FR-B07, MVP 부분 포함)
  employmentVerificationStatus EmploymentVerificationStatus @default(not_submitted)
  employmentVerifiedAt        DateTime?

  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@map("user_auths")
}

// =====================================================================
// 3. Profile / ProfileAnswer / RelationshipPreference / Photo
// =====================================================================

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobCategory     String?  // 직업군 (회사명 아님)
  // 나의 프롤로그 (자기소개)
  intro           String?  @db.Text
  // 라이프스타일 키워드 (배열)
  lifestyleTags   String[]

  // 운영 검수
  reviewStatus    ReviewStatus @default(pending)
  reviewedAt      DateTime?

  completionScore Int      @default(0)  // 0~100

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("profiles")
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// 이야기형 프로필 문답 (이야기의 목차 + 관계의 문체)
enum ProfileAnswerCategory {
  story         // 이야기의 목차: 일과 커리어, 주말과 휴식, 친구와 가족, 취향과 관심사
  relationship  // 관계의 문체: 연락 빈도, 대화 스타일, 관계 시작 속도, 갈등 해결, 애정 표현
}

model ProfileAnswer {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  ProfileAnswerCategory
  questionKey String              // 'work_career', 'weekend_rest', 'contact_frequency' 등 정책 상수
  answer    String                @db.Text

  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, questionKey])
  @@index([userId])
  @@map("profile_answers")
}

// 관계 목적/성향 데이터
enum RelationshipIntent {
  serious_long_term     // 진지한 장기 관계
  natural_dating        // 자연스럽게 시작하는 연애
  open_to_marriage      // 좋은 사람을 만나면 결혼도 가능
  casual_meeting        // 가벼운 만남 (MVP에서는 권장 풀 외)
  friendship_first      // 친구처럼 시작
}

enum RelationshipPace {
  slow
  moderate
  fast
}

enum ContactFrequency {
  low      // 가끔 연락
  medium   // 적당히
  high     // 자주
}

model RelationshipPreference {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  intent            RelationshipIntent
  pace              RelationshipPace
  contactFrequency  ContactFrequency
  // 기타 응답은 구조화된 jsonb로
  extra             Json?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("relationship_preferences")
}

enum PhotoType {
  main
  daily
  hobby
}

model Photo {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  photoType       PhotoType
  storageKey      String          // S3 object key (전체 URL 아님)
  isMain          Boolean         @default(false)
  reviewStatus    ReviewStatus    @default(pending)
  faceMatchStatus FaceMatchStatus @default(not_submitted)
  // 자동 검수(NSFW 등) 결과
  moderationFlags String[]        @default([])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([userId])
  @@map("photos")
}

// =====================================================================
// 4. Recommendation / RecommendationReason / UserAction
// =====================================================================

enum RecommendationStatus {
  created
  shown
  interested
  skipped
  expired
}

enum RecommendationGeneratedBy {
  rule
  ai
  admin
}

model Recommendation {
  id                  String                @id @default(cuid())
  // 추천을 받는 사용자
  userId              String
  user                User                  @relation("RecommendationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  // 추천 대상 사용자
  targetUserId        String
  targetUser          User                  @relation("RecommendationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  recommendationDate  DateTime              @db.Date
  batchId             String?
  rank                Int

  // 점수 (사용자 응답에 절대 노출 금지)
  totalScore          Float
  trustScore          Float?
  relationshipScore   Float?
  lifestyleScore      Float?
  conversationScore   Float?
  distanceScore       Float?
  profileQualityScore Float?

  status              RecommendationStatus  @default(created)
  shownAt             DateTime?

  reason              RecommendationReason?

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([userId, targetUserId, recommendationDate])
  @@index([userId, status, recommendationDate])
  @@index([batchId])
  @@map("recommendations")
}

model RecommendationReason {
  id                 String                    @id @default(cuid())
  recommendationId   String                    @unique
  recommendation     Recommendation            @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  // 사용자에게 공개되는 텍스트 (정책 상수에서 생성된 결과)
  summaryText        String                    @db.Text
  matchedPoints      String[]
  differencePoints   String[]
  conversationTopics String[]
  curatorMemo        String                    @db.Text

  // 생성 출처 (사용자에게 노출 금지)
  generatedBy        RecommendationGeneratedBy

  createdAt          DateTime                  @default(now())

  @@map("recommendation_reasons")
}

enum UserActionType {
  view_card
  view_profile
  view_report
  send_interest
  skip
  block_request
  report_request
}

// 거절 사유 - 상대에게 공개 금지
enum SkipReason {
  appearance_low_match
  intent_mismatch
  distance_mismatch
  conversation_style_mismatch
  job_lifestyle_mismatch
  values_mismatch
  insufficient_profile
  other
}

model UserAction {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation("ActionByUser", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId    String
  targetUser      User            @relation("ActionTowardUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  recommendationId String?

  actionType      UserActionType

  // 거절 사유는 SkipReason enum 또는 자유텍스트 (상대 비공개)
  skipReason      SkipReason?
  skipReasonNote  String?         @db.Text

  createdAt       DateTime        @default(now())

  @@index([userId, actionType, createdAt])
  @@index([targetUserId, actionType])
  @@map("user_actions")
}

// =====================================================================
// 5. Match
// =====================================================================

enum MatchStatus {
  active
  expired
  blocked
  reported
}

model Match {
  id              String         @id @default(cuid())
  // 정렬 일관성을 위해 항상 userAId < userBId 로 저장한다 (애플리케이션에서 정렬).
  userAId         String
  userA           User           @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId         String
  userB           User           @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  matchedAt       DateTime       @default(now())
  status          MatchStatus    @default(active)
  endedAt         DateTime?
  endReason       String?

  conversation    Conversation?

  @@unique([userAId, userBId])
  @@index([status])
  @@map("matches")
}

// =====================================================================
// 6. Conversation / Message / ContactExchange
// =====================================================================

enum ConversationStatus {
  active
  expired
  closed
  blocked
}

model Conversation {
  id            String              @id @default(cuid())
  matchId       String              @unique
  match         Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // 편의를 위해 매치 양측 사용자 ID 사본
  userAId       String
  userA         User                @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User                @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)

  status        ConversationStatus  @default(active)
  startedAt     DateTime            @default(now())
  expiresAt     DateTime            // 기본 7일 + 연장
  extensionsUsed Int                @default(0)
  endedAt       DateTime?
  endReason     String?

  messages      Message[]
  contactExchanges ContactExchange[]

  @@index([userAId, status])
  @@index([userBId, status])
  @@index([expiresAt])
  @@map("conversations")
}

enum MessageType {
  text
  system_topic        // 첫 대화 주제
  system_extension    // 대화 연장 알림
  system_contact      // 연락처 교환 시스템 메시지
  system_safety       // 안전 안내
  system_expiry       // 종료 안내
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String?      // system 메시지는 null
  sender          User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  messageType     MessageType  @default(text)
  content         String       @db.Text

  // 신고 보존을 위해 즉시 삭제하지 않음. soft delete 만 허용.
  deletedAt       DateTime?
  deletedBy       String?      // user, admin

  createdAt       DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum ContactExchangeStatus {
  requested
  accepted
  declined
  cancelled
  expired
}

enum ContactType {
  phone
  kakao
}

model ContactExchange {
  id              String                @id @default(cuid())
  conversationId  String
  conversation    Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  requesterId     String
  requester       User                  @relation("ContactRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  responderId     String
  responder       User                  @relation("ContactResponder", fields: [responderId], references: [id], onDelete: Cascade)

  contactType     ContactType
  status          ContactExchangeStatus @default(requested)

  // 평문은 양쪽 동의 시점에 새로 입력받는다. 저장된 User 데이터로 자동 노출 금지.
  // 동의 후 시스템 메시지로 한 번만 노출하고, 여기에는 보관 정책에 따라 마스킹된 형태만 저장 검토.
  requesterContactMasked String?
  responderContactMasked String?

  requestedAt     DateTime              @default(now())
  respondedAt     DateTime?

  @@index([conversationId])
  @@map("contact_exchanges")
}

// =====================================================================
// 7. Report / Block
// =====================================================================

enum ReportType {
  rude_message
  sexual_content
  harassment
  fake_information
  in_relationship
  scam_or_money_request
  external_contact_pressure
  other
}

enum ReportStatus {
  pending
  reviewing
  resolved
  rejected
}

model Report {
  id              String        @id @default(cuid())
  reporterId      String
  reporter        User          @relation("ReportFiler", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId    String
  targetUser      User          @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  // 신고 대상이 메시지/대화일 수 있음
  conversationId  String?
  messageId       String?

  reportType      ReportType
  description     String?       @db.Text  // 사용자에게 절대 공개 금지

  status          ReportStatus  @default(pending)
  resolutionNote  String?       @db.Text  // 운영자 메모, 사용자에게 공개 금지

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  resolvedAt      DateTime?

  @@index([targetUserId, status])
  @@index([status, createdAt])
  @@map("reports")
}

model Block {
  id            String   @id @default(cuid())
  blockerId     String
  blocker       User     @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId     String
  blocked       User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

// =====================================================================
// 8. Payment (MVP P2)
// =====================================================================

enum PaymentProductType {
  plus_subscription
  extra_recommendation
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  cancelled
}

model Payment {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  productType     PaymentProductType
  amount          Int                 // 원
  currency        String              @default("KRW")
  status          PaymentStatus       @default(pending)
  provider        String              // toss, iamport, iap_apple, iap_google
  providerTxId    String?             @unique

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  succeededAt     DateTime?
  refundedAt      DateTime?

  @@index([userId, status])
  @@map("payments")
}

// =====================================================================
// 9. Admin
// =====================================================================

enum AdminRole {
  owner
  manager
  reviewer
}

enum AdminStatus {
  active
  suspended
}

model AdminUser {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  role          AdminRole
  status        AdminStatus @default(active)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastLoginAt   DateTime?

  reviews       AdminReview[]
  auditLogs     AdminAuditLog[]

  @@map("admin_users")
}

enum AdminReviewTargetType {
  profile
  photo
  employment_auth
  report
  recommendation
}

enum AdminReviewStatus {
  pending
  approved
  rejected
}

model AdminReview {
  id              String                @id @default(cuid())
  targetType      AdminReviewTargetType
  targetId        String
  reviewerId      String?
  reviewer        AdminUser?            @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  status          AdminReviewStatus     @default(pending)
  memo            String?               @db.Text  // 내부용, 사용자에게 공개 금지

  createdAt       DateTime              @default(now())
  reviewedAt      DateTime?

  @@index([targetType, status])
  @@map("admin_reviews")
}

// 운영자 모든 액션을 추적 (보안/감사)
model AdminAuditLog {
  id          String     @id @default(cuid())
  adminId     String
  admin       AdminUser  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action      String     // suspend_user, approve_photo, view_face_image_url 등
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime   @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}
