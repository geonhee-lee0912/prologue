# =====================================================================
# 프롤로그 환경변수 템플릿 (루트)
#
# 각 앱별로 .env 가 따로 있다 (apps/api/.env, apps/mobile/.env, apps/admin/.env).
# 이 루트 .env 는 개발자 노트와 공유 변수만 둔다.
#
# 운영 환경에서는 .env 파일을 사용하지 않는다.
# - NestJS: Railway 의 환경 변수 UI 에서 관리
# - Mobile: EAS Secret 으로 관리
# - Admin: Vercel 환경 변수 UI 에서 관리
# - Supabase: Supabase 대시보드 (Auth/Storage 설정)
# =====================================================================

# ----- 공통 -----
NODE_ENV=development
TZ=Asia/Seoul

# ----- 작업 환경 식별 -----
# 'dev' 또는 'prod' — 어떤 Supabase 프로젝트를 사용 중인지 명확히 하기 위함
PROLOGUE_ENV=dev
