# =====================================================================
# apps/api/.env.example
# NestJS 백엔드 환경변수 (Railway 운영, 로컬 개발용 .env 도 동일 키)
#
# 절대 실제 시크릿을 git 에 올리지 말 것.
# 운영 시크릿은 Railway 환경 변수 UI 에서 관리.
# =====================================================================

# ----- 앱 -----
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3002,exp://*

# ----- Supabase (DB / Auth / Storage / Realtime) -----
# dev 프로젝트와 prod 프로젝트의 값이 다름. PROLOGUE_ENV 에 맞는 값을 사용.
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ----- 데이터베이스 (Prisma 가 Supabase Postgres 에 연결) -----
# Supabase 대시보드 > Settings > Database > Connection String 에서 확인
# Prisma 는 connection pooler 를 사용하는 것을 권장 (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# 마이그레이션 시에는 direct connection (port 5432) 사용
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ----- Redis (Upstash) -----
# Upstash 대시보드 > 데이터베이스 > Connect > "redis://" URL 복사
REDIS_URL="rediss://default:<password>@<endpoint>.upstash.io:6379"

# ----- 본인 인증 (FR-B01) -----
IDENTITY_VERIFICATION_PROVIDER=mock      # mock | pass | nice
# PASS_CLIENT_ID=
# PASS_CLIENT_SECRET=
# PASS_SITE_CODE=
# NICE_CLIENT_ID=
# NICE_CLIENT_SECRET=

# ----- SMS OTP (FR-A01, FR-A02) -----
SMS_PROVIDER=mock                         # mock | nhn_toast | aligo
# NHN_TOAST_APP_KEY=
# NHN_TOAST_SECRET_KEY=
# NHN_TOAST_SENDER_NUMBER=
SMS_OTP_TTL_SECONDS=180
SMS_OTP_MAX_ATTEMPTS=5

# ----- 얼굴 인증 (FR-B02) -----
FACE_VERIFICATION_PROVIDER=mock           # mock | aws_rekognition | clova
FACE_VERIFICATION_THRESHOLD=90
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# CLOVA_API_KEY=

# ----- 사진 검수 (FR-C02) -----
PHOTO_MODERATION_PROVIDER=mock            # mock | aws_rekognition

# ----- 푸시 알림 -----
PUSH_PROVIDER=mock                        # mock | expo
# EXPO_ACCESS_TOKEN=

# ----- 결제 (MVP 후순위) -----
PAYMENT_PROVIDER=mock                     # mock | toss | iamport | iap

# ----- 로깅/모니터링 -----
LOG_LEVEL=debug                           # 운영: info
# SENTRY_DSN=

# ----- 보안 -----
# 휴대폰 번호 해시용 pepper (운영에서는 반드시 강한 랜덤 값으로 교체)
PHONE_HASH_PEPPER=dev-only-pepper-replace-in-prod

# ----- 추천 시스템 -----
RECOMMENDATION_BATCH_CRON="0 6 * * *"     # 매일 오전 6시
RECOMMENDATION_DAILY_LIMIT_FREE=3
RECOMMENDATION_DAILY_LIMIT_PLUS=10

# ----- 정책 (packages/shared/policy.ts 와 동기화) -----
CONVERSATION_DEFAULT_DAYS=7
CONVERSATION_MAX_DAYS_FREE=14
CONVERSATION_MAX_DAYS_PLUS=21
