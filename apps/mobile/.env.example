# =====================================================================
# apps/mobile/.env.example
# Expo 사용자 앱 환경변수
#
# Expo 는 EXPO_PUBLIC_ prefix 가 있는 변수만 클라이언트에 노출한다.
# 시크릿은 절대 EXPO_PUBLIC_ prefix 를 붙이지 말 것.
#
# 운영 시크릿은 EAS Secret 으로 관리.
# =====================================================================

# ----- 환경 식별 -----
EXPO_PUBLIC_ENV=development                # development | staging | production

# ----- 백엔드 API (NestJS) -----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ----- Supabase -----
# 모바일은 anon key 만 사용. service role key 는 절대 모바일에 두지 않음.
# RLS 가 권한을 강제하므로 anon key 노출은 안전.
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----- Sentry (선택) -----
# EXPO_PUBLIC_SENTRY_DSN=
