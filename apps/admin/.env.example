# =====================================================================
# apps/admin/.env.example
# Next.js 운영자 도구 환경변수
#
# Next.js 는 NEXT_PUBLIC_ prefix 가 있는 변수만 브라우저에 노출.
# 시크릿은 절대 NEXT_PUBLIC_ prefix 를 붙이지 말 것.
#
# 운영 시크릿은 Vercel 환경 변수 UI 에서 관리.
# =====================================================================

# ----- 환경 식별 -----
NEXT_PUBLIC_ENV=development

# ----- 백엔드 운영자 API (NestJS) -----
ADMIN_API_BASE_URL=http://localhost:3001/api/admin/v1
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:3001/api/admin/v1

# ----- Supabase (운영자 인증용) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# 서버 컴포넌트/Server Action 에서만 사용
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----- 운영자 세션 (Iron Session) -----
ADMIN_SESSION_SECRET=dev-only-admin-session-secret-replace-in-prod-min-32-chars
ADMIN_SESSION_COOKIE_NAME=prologue_admin_session

# ----- Sentry (선택) -----
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
