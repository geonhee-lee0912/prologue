{
  "name": "@prologue/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "프롤로그 사용자 앱 (Expo / React Native)",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
