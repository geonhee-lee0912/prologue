{
  "expo": {
    "name": "Prologue",
    "slug": "prologue",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "prologue",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.prologue.dev"
    },
    "android": {
      "package": "app.prologue.dev"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
